{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lec.example.org/truthcert.schema.json",
  "title": "TruthCert certificate (Bronze)",
  "type": "object",
  "required": [
    "certificate_version",
    "assurance_level",
    "decision",
    "run_id",
    "created_at_utc",
    "inputs",
    "validator_results",
    "provenance_check",
    "disagreements_summary"
  ],
  "properties": {
    "certificate_version": {
      "type": "string"
    },
    "assurance_level": {
      "type": "string",
      "enum": [
        "bronze",
        "silver",
        "gold"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "PASS",
        "FLAG",
        "FAIL"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "inputs": {
      "type": "object",
      "required": [
        "extraction_paths"
      ],
      "properties": {
        "extraction_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "meta": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "validator_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "status",
          "findings_count"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "FAIL"
            ]
          },
          "findings_count": {
            "type": "integer",
            "minimum": 0
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "provenance_check": {
      "type": "object",
      "required": [
        "status",
        "missing_critical_fields_count"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "missing_critical_fields_count": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "disagreements_summary": {
      "type": "object",
      "required": [
        "status",
        "fields_disagreed_count"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "OK",
            "FLAGGED"
          ]
        },
        "fields_disagreed_count": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}